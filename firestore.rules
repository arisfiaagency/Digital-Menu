rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function platformProfileRef() {
      return /databases/$(database)/documents/adminProfiles/$(request.auth.uid);
    }

    function hasPlatformProfile() {
      return signedIn() && exists(platformProfileRef());
    }

    function platformData() {
      return get(platformProfileRef()).data;
    }

    function isPlatformAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || (
            hasPlatformProfile()
            && platformData().isAdmin == true
            && platformData().disabled != true
          )
        );
    }

    function isPlatformFullAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || (
            hasPlatformProfile()
            && platformData().isAdmin == true
            && platformData().disabled != true
            && platformData().role != 'employee'
          )
        );
    }

    function tenantProfileRef(clientId) {
      return /databases/$(database)/documents/clients/$(clientId)/adminProfiles/$(request.auth.uid);
    }

    function hasTenantProfile(clientId) {
      return signedIn() && exists(tenantProfileRef(clientId));
    }

    function tenantData(clientId) {
      return get(tenantProfileRef(clientId)).data;
    }

    function isTenantAdmin(clientId) {
      return isPlatformFullAdmin()
        || (
          hasTenantProfile(clientId)
          && tenantData(clientId).isAdmin == true
          && tenantData(clientId).disabled != true
        );
    }

    function isTenantFullAdmin(clientId) {
      return isPlatformFullAdmin()
        || (
          hasTenantProfile(clientId)
          && tenantData(clientId).isAdmin == true
          && tenantData(clientId).disabled != true
          && tenantData(clientId).role != 'employee'
        );
    }

    function hasTenantFeature(clientId, feature) {
      return isTenantFullAdmin(clientId)
        || (
          isTenantAdmin(clientId)
          && tenantData(clientId).get('permissions', {}).get(feature, false) == true
        );
    }

    match /adminProfiles/{uid} {
      allow get: if isPlatformAdmin() || (signedIn() && request.auth.uid == uid);
      allow list, create, update, delete: if isPlatformFullAdmin();
    }

    match /usernames/{username} {
      allow get: if true;
      allow list, create, update, delete: if isPlatformFullAdmin();
    }

    match /platformPayments/{paymentId} {
      allow read: if isPlatformAdmin();
      allow create, update, delete: if isPlatformFullAdmin();
    }

    match /clients/{clientId} {
      allow get: if (resource.data.status == 'active' && resource.data.get('blocked', false) != true) || isPlatformAdmin();
      allow list: if isPlatformAdmin();
      allow create, update, delete: if isPlatformFullAdmin();

      match /categories/{categoryId} {
        allow get, list: if isTenantAdmin(clientId);
        allow create, update, delete: if hasTenantFeature(clientId, 'categories');
      }

      match /menuItems/{menuItemId} {
        allow get, list: if isTenantAdmin(clientId);
        allow create, update, delete: if hasTenantFeature(clientId, 'menuItems');
      }

      match /settings/{settingsId} {
        allow get, list: if settingsId in ['general', 'menu', 'appearance', 'pos'] && isTenantAdmin(clientId);
        allow create: if settingsId in ['general', 'menu', 'appearance', 'pos'] && (settingsId == 'pos'
          ? hasTenantFeature(clientId, 'pos')
            && (isTenantFullAdmin(clientId) || request.resource.data.get('completedOrders', []).size() == 0)
          : hasTenantFeature(clientId, 'settings'));
        allow update: if settingsId in ['general', 'menu', 'appearance', 'pos'] && (settingsId == 'pos'
          ? hasTenantFeature(clientId, 'pos')
            && (
              isTenantFullAdmin(clientId)
              || request.resource.data.get('completedOrders', []) == resource.data.get('completedOrders', [])
            )
          : hasTenantFeature(clientId, 'settings'));
        allow delete: if settingsId in ['general', 'menu', 'appearance', 'pos'] && (settingsId == 'pos' ? isTenantFullAdmin(clientId) : hasTenantFeature(clientId, 'settings'));
      }

      match /completedOrders/{orderId} {
        allow read: if isTenantAdmin(clientId);
        allow create: if hasTenantFeature(clientId, 'pos')
          && request.resource.data.get('status', 'completed') == 'completed';
        allow update, delete: if isTenantFullAdmin(clientId);
      }

      match /expenses/{expenseId} {
        allow read: if isTenantAdmin(clientId);
        allow create: if hasTenantFeature(clientId, 'expenses')
          && request.resource.data.get('status', 'active') == 'active';
        allow update, delete: if isTenantFullAdmin(clientId);
      }

      match /adminProfiles/{uid} {
        allow get: if isTenantAdmin(clientId) || (signedIn() && request.auth.uid == uid);
        allow list, create, update, delete: if isTenantFullAdmin(clientId);
      }

      match /usernames/{username} {
        allow get: if true;
        allow list, create, update, delete: if isTenantFullAdmin(clientId);
      }

      match /auditLogs/{logId} {
        allow read, create: if isTenantAdmin(clientId);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
