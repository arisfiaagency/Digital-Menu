# Public site URL (no trailing slash). Used for QR links and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: redirect legacy /menu to this client slug. Defaults to "demo" when unset.

# Firebase Web (client SDK + public Firestore REST reads)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (seed, create-admin, API routes, cron)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Cloudflare R2 (menu images). Folder per cafe: clients/{slug}/
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=digital-menu
# Public base URL with no trailing slash (custom domain or https://pub-….r2.dev)
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_URL=

# Optional: authorize Vercel cron for /api/cron/cleanup-expired-images
# CRON_SECRET=
