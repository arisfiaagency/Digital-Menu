# Public site URL (no trailing slash). Used for QR links and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: redirect legacy /menu to this client slug. Defaults to "demo" when unset.
# NEXT_PUBLIC_DEFAULT_CLIENT_SLUG=demo

# Firebase Web (client SDK + public Firestore REST reads)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (seed, create-admin, API routes, cron)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Supabase Storage (menu images)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=menu-images
SUPABASE_SERVICE_ROLE_KEY=

# Optional: authorize Vercel cron for /api/cron/cleanup-expired-images
# CRON_SECRET=
